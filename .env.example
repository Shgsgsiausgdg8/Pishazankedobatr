# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FARAZGOLD_SESSIONID: Get this from your browser cookies on farazgold.com
FARAZGOLD_SESSIONID="your_session_id_here"

# FARAZGOLD_CSRFTOKEN: Get this from your browser cookies on farazgold.com
FARAZGOLD_CSRFTOKEN="your_csrf_token_here"

# FARAZGOLD_WS_URL: The websocket URL (demo or real)
FARAZGOLD_WS_URL="wss://demo.farazgold.com/ws/"
